# BNB Hack Track 2 — Gate = CMC Strategy Skill product surface (execution secondary)
NEXT_PUBLIC_MERIDIAN_TRACK2_PRIORITY=1

# WalletConnect / Reown — Trust Wallet mobile + desktop (https://cloud.reown.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# BNB Smart Chain Testnet — wallet + demo trades (BNB Hack Track 2)
NEXT_PUBLIC_BSC_CHAIN_ID=97
NEXT_PUBLIC_BSC_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545
# Faucet: https://testnet.bnbchain.org/faucet-smart

# CoinMarketCap — BNB Hack Track 2 (quotes + MCP; same key often works for both)
CMC_API_KEY=
CMC_MCP_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# OpenRouter — OpenAI-compatible fallback for PRISM/NEXUS AI (https://openrouter.ai)
OPENROUTER_API_KEY=
