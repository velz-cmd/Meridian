# OPENROUTER_APP_NAME=MERIDIAN
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Market Intelligence
NEWS_API_KEY=
# Event Registry (newsapi.ai) — structured macro headlines for PRISM
EVENT_REGISTRY_API_KEY=
# FRED — St. Louis Fed macro series (free key: https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=
# Binance public market data (optional base; default https://data-api.binance.vision)
# BINANCE_DATA_API_BASE=https://data-api.binance.vision
# Dune — on-chain SQL (https://dune.com/settings/api)
DUNE_API_KEY=
# Public dashboard for BNB Hack / judge application (paste your dune.com dashboard URL)
NEXT_PUBLIC_DUNE_DASHBOARD_URL=
DUNE_DASHBOARD_URL=
# Optional iframe embed (Dune → Share → Embed)
NEXT_PUBLIC_DUNE_EMBED_URL=
DUNE_EMBED_URL=
# Saved query IDs — API pulls live rows into /analytics
DUNE_BNB_STATS_QUERY_ID=
DUNE_BNB_TX_QUERY_ID=
DUNE_PRISM_QUERY_ID=
# Public launch date shown on /analytics (ISO: YYYY-MM-DD) — MERIDIAN went live May 2026
NEXT_PUBLIC_SITE_LAUNCH_DATE=2026-05-26
COINGECKO_API_KEY=
# GeckoTerminal — free, no key (Alpha scan trending + DexScreener merge)
# Moralis — token metadata (optional)
MORALIS_API_KEY=
# Etherscan / Basescan / Arbiscan — contract verify (optional, same key style per chain)
ETHERSCAN_API_KEY=
# Gold Rush / Covalent (optional — COVALENT_API_KEY or GOLDRUSH_API_KEY)
COVALENT_API_KEY=
GOLDRUSH_API_KEY=
# Twitter scrapers (twikit, nitter, snscrape) are Python/local — not used on Vercel serverless.
# Narrative acceleration uses news, meme feeds, Reddit, GeckoTerminal; dev momentum uses GitHub REST.
# Optional — raises GitHub search rate limits for Alpha "developer momentum" layer
GITHUB_TOKEN=
# GH_TOKEN=   # alias

# Social intelligence — default FREE mode (skips paid LunarCrush/Neynar API calls)
SOCIAL_USE_PREMIUM=false
# LunarCrush — optional; Individual+ subscription (only used if SOCIAL_USE_PREMIUM=true)
LUNARCRUSH_API_KEY=
# LUNARCRUSH_API_BASE=https://lunarcrush.com/api4
# Neynar — Snapchain hub probe always works; cast search needs paid plan + NEYNAR_USE_SEARCH=true
NEYNAR_API_KEY=
# NEYNAR_API_BASE=https://snapchain-api.neynar.com
# NEYNAR_USE_SEARCH=true
# Social Data API (socialdata.tools) — Twitter/X search for narrative velocity
SOCIAL_DATA_API_KEY=

# --- Community narrative (Telegram, Discord, Stocktwits, RapidAPI X) ---

# Telegram Bot API — create via @BotFather, add bot to your alpha/crypto groups
TELEGRAM_BOT_TOKEN=

# Discord — OAuth2 Client ID is for login; message search needs a BOT token + guild IDs
# Developer Portal → Bot → Reset Token → DISCORD_BOT_TOKEN
# OAuth2 app "arc" example client id (public): 1309083731577802982
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
# Comma-separated server IDs where the bot can search messages (MESSAGE_CONTENT intent)
DISCORD_GUILD_IDS=

# Stocktwits enterprise news (Basic auth) — enterprise-support@stocktwits.com
STOCKTWITS_USERNAME=
STOCKTWITS_PASSWORD=

# RapidAPI Twitter (optional) — host from RapidAPI subscription page
RAPIDAPI_KEY=
RAPIDAPI_TWITTER_HOST=twitter241.p.rapidapi.com
# RAPIDAPI_TWITTER_PROBE_PATH=/get-users-v2
# RAPIDAPI_TWITTER_PROBE_USERS=44196397
# RAPIDAPI_TWITTER_SEARCH_PATH=/search
# RAPIDAPI_TWITTER_HOST_ALT=twitter-api45.p.rapidapi.com

# Reddit public JSON (no OAuth) — used automatically when OAuth vars are missing
# REDDIT_PUBLIC_USER_AGENT=web:trader-arc:1.0 (by /u/your_username)

# ApeWisdom — free Reddit/4chan mention ranks (no key)
# https://apewisdom.io/api/v1.0/filter/all-crypto

# Hacker News — Algolia search API (no key)

# Perception.to narrative index — https://api.perception.to
PERCEPTION_API_KEY=

# GMGN OpenAPI — https://gmgn.ai/ai (create API key + upload Ed25519 public key)
GMGN_API_KEY=
# GMGN_PRIVATE_KEY=   # Ed25519 PEM for live Sol/BSC/Base trades only — NEVER commit. Arc Testnet demo trades do not use this.
# GMGN_HOST=https://openapi.gmgn.ai

# 6551 OpenNews + OpenTwitter — https://6551.io/mcp (one account key usually works for both)
# Easiest on Vercel: set only API_KEY_6551 to your single key
API_KEY_6551=
# Or use product-specific names (same key in both is fine):
OPENNEWS_TOKEN=
TWITTER_TOKEN=
# OPENNEWS_API_BASE=https://ai.6551.io

# Reddit Data API OAuth — optional upgrade over public JSON
# Create a "script" or "web app" at https://www.reddit.com/prefs/apps
# USER_AGENT format: platform:appid:version (by reddit_username)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:trader-arc:1.0 (by /u/your_reddit_username)

# Birdeye — holders, whales, snipers, live swaps (required for Token intel)
BIRDEYE_API_KEY=
# Alternates also supported: BIRDEYE_KEY, BDS_API_KEY
# Scans use Birdeye sparingly (lite whales + capped OHLCV); full stack only on per-token Analyze.
# Set the same key in Vercel — never commit real keys to git.

# Private ops dashboard — /ops?key=YOUR_SECRET (not linked in public nav)
MERIDIAN_OPS_KEY=

# Blockchain Infrastructure
ALCHEMY_API_KEY=
NEXT_PUBLIC_ALCHEMY_BASE_RPC=
NEXT_PUBLIC_ALCHEMY_ETH_RPC=

# Swap — 0x API for EVM on-chain quotes
ZEROX_API_KEY=

# Supabase — Agent Memory (new publishable + secret keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# One-time setup: npm run setup:portfolio (Database password from Dashboard → Settings → Database)
# SUPABASE_DB_PASSWORD=
# Or: SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@....pooler.supabase.com:6543/postgres
# Run all tables: npm run setup:supabase (needs one of below)
# SUPABASE_ACCESS_TOKEN=   https://supabase.com/dashboard/account/tokens
# SUPABASE_DB_PASSWORD=    Project → Settings → Database
# SUPABASE_PROJECT_REF=pjtkiktpdvhghkqwqpok
# Legacy JWT keys (optional fallback)
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Circle Developer Platform (sandbox/test) — optional per-user agent wallets
CIRCLE_API_KEY=
CIRCLE_WALLET_SET_ID=
CIRCLE_ENTITY_SECRET_CIPHERTEXT=
CIRCLE_KIT_KEY=
CIRCLE_API_BASE=https://api-sandbox.circle.com/v1/w3s

# Circle Agents + x402 (NEXUS premium APIs — /api/nexus/scan, /api/nexus/token/dossier)
# Seller wallet receives USDC via Gateway; defaults to agent vault address
X402_SELLER_ADDRESS=
X402_FACILITATOR_URL=https://gateway-api-testnet.circle.com
X402_NETWORKS=eip155:5042002
X402_SCAN_PRICE=$0.05
X402_DOSSIER_PRICE=$0.01
# List on https://agents.circle.com/ — external agents pay x402; NEXUS UI bypasses via x-meridian-client header

# Agent vault — shared treasury for Autopilot deposits (BSC Testnet tBNB)
NEXT_PUBLIC_AGENT_VAULT_ADDRESS=0x11c1695A3AC5EF9d0B92572f0730F7AC3C87A715
# Or derive vault from server key (address = public key of this key)
ARC_AGENT_PRIVATE_KEY=
# BSC_AGENT_PRIVATE_KEY=   # alias for vault key on BSC Testnet

# Arc Testnet — USDC-native fees (Circle Agora hackathon)
# Arc testnet v0.7.1 — use Circle RPC (https://github.com/circlefin/arc-node/releases/tag/v0.7.1)
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_AGENT_PRIVATE_KEY=
# Foundry Counter.sol on Arc — set after: cd contracts && forge script … --broadcast
NEXT_PUBLIC_ARC_COUNTER_ADDRESS=
